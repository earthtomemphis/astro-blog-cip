---
import { Icon } from 'astro-icon/components';

interface Props {
	text: string;
	href: string;
	style: 'primary' | 'secondary';
	icon?: {
		name: string;
		side: 'left' | 'right';
	};
	isFilled?: boolean;
	borderVisable?: boolean;
	cleasses?: string;
}

const {
	text,
	href,
	style,
	icon,
	isFilled = true,
	borderVisable = false,
	cleasses,
	...rest
} = Astro.props as Props;
---

<a
	href={href}
	class:list={[
		'link',
		cleasses,
		style,
		{ filled: isFilled, bordered: borderVisable },
	]}
	{...rest}
>
	{
		icon && icon.side === 'left' && (
			<Icon name={icon.name} hanging="24" width="24" />
		)
	}
	<span>{text}</span>
	{
		icon && icon.side === 'right' && (
			<Icon name={icon.name} hanging="24" width="24" />
		)
	}
</a>
