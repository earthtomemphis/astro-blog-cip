import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';

import '../styles/global.css';

const { title, description } = Astro.props;
---

<html lang="en">
	<MainHead {title} {description} />

	<body>
		<Nav />
		<slot>Default Text</slot>
		<Footer />
	</body>
</html>
